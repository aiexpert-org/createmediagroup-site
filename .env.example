# Wait list intake (/api/contact). Set these in Vercel → Project → Settings →
# Environment Variables. Until RESEND_API_KEY is set, the wait list form falls
# back to a plain mailto so no signup is ever lost.

# Resend (emails each signup to Emily). https://resend.com
RESEND_API_KEY=
# Optional overrides. Defaults: WAITLIST_TO=emily@createchurchmedia.com,
# WAITLIST_FROM="Create Church Media <noreply@createchurchmedia.com>".
# The FROM domain must be verified in Resend.
WAITLIST_TO=
WAITLIST_FROM=

# GoHighLevel (best-effort: creates a contact tagged "wait-list-2026").
# Both must be set for the CRM sync to run; the email send works without them.
GHL_API_KEY=
GHL_LOCATION_ID=

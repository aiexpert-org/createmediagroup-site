# Wait list intake (/api/contact). Set these in Vercel → Project → Settings →
# Environment Variables. Until RESEND_API_KEY is set, the wait list form falls
# back to a plain mailto so no signup is ever lost.

# Resend (emails each signup to Emily). https://resend.com
RESEND_API_KEY=
# Optional overrides. Defaults: WAITLIST_TO=emily@createchurchmedia.com,
# WAITLIST_FROM="Create Church Media <noreply@createchurchmedia.com>".
# The FROM domain must be verified in Resend.
WAITLIST_TO=
WAITLIST_FROM=

# Google Sheet logging via an Apps Script web app. Each signup is appended as a
# row. Leave unset to skip the Sheet write; the email send works without it.
# See _handoff/google-sheets-waitlist-setup-2026-06-15.md for setup.
WAITLIST_SHEET_WEBHOOK_URL=

# The wait list form also captures an optional `referralCode` value. It is
# propagated to the Google Sheet and included in Emily's signup email. No env
# var is needed for it.
